SELECT s0."Key" AS "Date", (
    SELECT COALESCE(sum(s1."QuantitySold"::numeric * p."Price"), 0.0)
    FROM (
        SELECT s2."ProductId", s2."QuantitySold", date_trunc('day', s2."SaleDate", 'UTC') AS "Key"
        FROM "Sales" AS s2
        WHERE s2."SaleDate" >= @fromDate
    ) AS s1
    INNER JOIN "Products" AS p ON s1."ProductId" = p."Id"
    WHERE s0."Key" = s1."Key" OR (s0."Key" IS NULL AND s1."Key" IS NULL)) AS "Revenue"
FROM (
    SELECT date_trunc('day', s."SaleDate", 'UTC') AS "Key"
    FROM "Sales" AS s
    WHERE s."SaleDate" >= @fromDate
) AS s0
GROUP BY s0."Key"
ORDER BY s0."Key"
